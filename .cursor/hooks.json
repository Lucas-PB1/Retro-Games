{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "node .cursor/hooks/guard-shell.mjs",
        "failClosed": false
      }
    ],
    "beforeReadFile": [
      {
        "command": "node .cursor/hooks/guard-read.mjs",
        "failClosed": false
      }
    ]
  }
}
