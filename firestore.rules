rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net: Default Deny All
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Global Helper Primitives
    // Limites de string alinhados a src/lib/limits.ts (FIELD_MAX).
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Conta autenticada com e-mail verificado (Google Auth no client).
    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function optionalStringMax(data, key, max) {
      return !(key in data)
        || data[key] == null
        || (data[key] is string && data[key].size() <= max);
    }
    
    // Entity Schema Validators
    
    function isValidHackCode(data) {
      return data.keys().hasAll(['id', 'nome', 'movimentos', 'desc', 'revelado', 'userId', 'createdAt'])
        && data.keys().size() == 7
        && data.id is string && data.id.size() <= 128
        && data.nome is string && data.nome.size() >= 1 && data.nome.size() <= 100
        && data.movimentos is string && data.movimentos.size() >= 1 && data.movimentos.size() <= 100
        && data.desc is string && data.desc.size() <= 250
        && data.revelado is bool
        && data.userId is string && data.userId == request.auth.uid
        && data.createdAt is timestamp;
    }
    
    function isValidConsequence(data) {
      return data.keys().hasAll(['id', 'nome', 'desc', 'userId', 'createdAt'])
        && data.keys().size() == 5
        && data.id is string && data.id.size() <= 128
        && data.nome is string && data.nome.size() >= 1 && data.nome.size() <= 100
        && data.desc is string && data.desc.size() >= 1 && data.desc.size() <= 250
        && data.userId is string && data.userId == request.auth.uid
        && data.createdAt is timestamp;
    }
    
    function isValidLog(data) {
      return data.keys().hasAll(['id', 'userId', 'userEmail', 'userName', 'tipo', 'createdAt'])
        && data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId == request.auth.uid
        && data.userEmail is string && data.userEmail.size() <= 128
        && data.userName is string && data.userName.size() <= 128
        && data.tipo is string && (data.tipo == 'roll_hack' || data.tipo == 'consequence' || data.tipo == 'reset')
        && data.createdAt is timestamp
        && optionalStringMax(data, 'photoURL', 2048)
        && optionalStringMax(data, 'hackNome', 250)
        && optionalStringMax(data, 'hackMovimentos', 100)
        && optionalStringMax(data, 'conseqNome', 100)
        && optionalStringMax(data, 'conseqDesc', 250);
    }
    
    // Core Collections — sessão compartilhada: qualquer operador verificado
    // pode ler/apagar fitas (jogo em grupo); create/update amarra userId.
    
    match /hack_codes/{hackId} {
      allow read: if isVerified();
      
      allow create: if isVerified() 
        && isValidId(hackId) 
        && isValidHackCode(incoming())
        && incoming().createdAt == request.time;
        
      allow update: if isVerified()
        && isValidId(hackId)
        && isValidHackCode(incoming())
        && incoming().id == existing().id
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && (incoming().diff(existing()).affectedKeys().hasOnly(['revelado']) 
            || incoming().diff(existing()).affectedKeys().hasOnly(['nome', 'movimentos', 'desc'])
            || incoming().diff(existing()).affectedKeys().size() == 0);
            
      allow delete: if isVerified();
    }
    
    match /consequences/{consequenceId} {
      allow read: if isVerified();
      
      allow create: if isVerified()
        && isValidId(consequenceId)
        && isValidConsequence(incoming())
        && incoming().createdAt == request.time;
        
      allow update: if isVerified()
        && isValidId(consequenceId)
        && isValidConsequence(incoming())
        && incoming().id == existing().id
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && (incoming().diff(existing()).affectedKeys().hasOnly(['nome', 'desc'])
            || incoming().diff(existing()).affectedKeys().size() == 0);
            
      allow delete: if isVerified();
    }
    
    match /logs/{logId} {
      allow read: if isVerified();
      
      allow create: if isVerified()
        && isValidId(logId)
        && isValidLog(incoming())
        && incoming().createdAt == request.time;
        
      allow update: if false;
      allow delete: if isVerified();
    }
  }
}
